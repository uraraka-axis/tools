# このファイルを .env にコピーして値を入れてください。

# Google Chat の Incoming Webhook URL（必須）
# スペース → 「アプリと統合」→「Webhook」→ 作成 で取得
GOOGLE_CHAT_WEBHOOK=https://chat.googleapis.com/v1/spaces/XXXX/messages?key=...&token=...

# Anthropic API キー（任意。あると自社目線スコアリングの精度が上がる）
# 未設定でもキーワード辞書ベースのフォールバックで動作します。
ANTHROPIC_API_KEY=sk-ant-...
